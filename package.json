{
  "name": "ocr-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Quark Vision OCR API",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ocr-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
